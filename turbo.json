{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "lint:css": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:a11y": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "validate": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "validate:exports": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "validate:tokens": {
      "outputs": []
    }
  }
}
