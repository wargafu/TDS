{
  "name": "@tds-tchad/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": [
    "**/*.css",
    "dist/**/*.css"
  ],
  "files": [
    "dist",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "generate:tokens": "node scripts/generate-tokens.mjs",
    "test": "vitest run",
    "lint:css": "stylelint \"src/**/*.css\"",
    "clean": "node scripts/clean.mjs",
    "dev": "tsc --build tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "validate:exports": "node scripts/validate-exports.mjs",
    "validate:tokens": "node scripts/validate-tokens.mjs",
    "validate": "pnpm validate:tokens && pnpm build && pnpm validate:exports",
    "prepare": "node scripts/build.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./base.css": "./dist/base.css",
    "./tokens": {
      "import": "./dist/tokens/index.js",
      "types": "./dist/tokens/index.d.ts"
    },
    "./components": {
      "import": "./dist/components/index.js",
      "types": "./dist/components/index.d.ts"
    },
    "./components/button": {
      "import": "./dist/components/button/index.js",
      "types": "./dist/components/button/index.d.ts"
    },
    "./components/button/button.css": "./dist/components/button/button.css",
    "./components/input": {
      "import": "./dist/components/input/index.js",
      "types": "./dist/components/input/index.d.ts"
    },
    "./components/input/input.css": "./dist/components/input/input.css",
    "./components/alert": {
      "import": "./dist/components/alert/index.js",
      "types": "./dist/components/alert/index.d.ts"
    },
    "./components/alert/alert.css": "./dist/components/alert/alert.css",
    "./components/badge": {
      "import": "./dist/components/badge/index.js",
      "types": "./dist/components/badge/index.d.ts"
    },
    "./components/badge/badge.css": "./dist/components/badge/badge.css",
    "./components/card": {
      "import": "./dist/components/card/index.js",
      "types": "./dist/components/card/index.d.ts"
    },
    "./components/card/card.css": "./dist/components/card/card.css",
    "./components/link": {
      "import": "./dist/components/link/index.js",
      "types": "./dist/components/link/index.d.ts"
    },
    "./components/link/link.css": "./dist/components/link/link.css",
    "./components/table": {
      "import": "./dist/components/table/index.js",
      "types": "./dist/components/table/index.d.ts"
    },
    "./components/table/table.css": "./dist/components/table/table.css",
    "./components/header": {
      "import": "./dist/components/header/index.js",
      "types": "./dist/components/header/index.d.ts"
    },
    "./components/header/header.css": "./dist/components/header/header.css",
    "./components/nav": {
      "import": "./dist/components/nav/index.js",
      "types": "./dist/components/nav/index.d.ts"
    },
    "./components/nav/nav.css": "./dist/components/nav/nav.css",
    "./components/breadcrumb": {
      "import": "./dist/components/breadcrumb/index.js",
      "types": "./dist/components/breadcrumb/index.d.ts"
    },
    "./components/breadcrumb/breadcrumb.css": "./dist/components/breadcrumb/breadcrumb.css",
    "./components/pagination": {
      "import": "./dist/components/pagination/index.js",
      "types": "./dist/components/pagination/index.d.ts"
    },
    "./components/pagination/pagination.css": "./dist/components/pagination/pagination.css",
    "./components/modal": {
      "import": "./dist/components/modal/index.js",
      "types": "./dist/components/modal/index.d.ts"
    },
    "./components/modal/modal.css": "./dist/components/modal/modal.css",
    "./components/skip-link": {
      "import": "./dist/components/skip-link/index.js",
      "types": "./dist/components/skip-link/index.d.ts"
    },
    "./components/skip-link/skip-link.css": "./dist/components/skip-link/skip-link.css",
    "./components/footer": {
      "import": "./dist/components/footer/index.js",
      "types": "./dist/components/footer/index.d.ts"
    },
    "./components/footer/footer.css": "./dist/components/footer/footer.css",
    "./components/accordion": {
      "import": "./dist/components/accordion/index.js",
      "types": "./dist/components/accordion/index.d.ts"
    },
    "./components/accordion/accordion.css": "./dist/components/accordion/accordion.css",
    "./components/tabs": {
      "import": "./dist/components/tabs/index.js",
      "types": "./dist/components/tabs/index.d.ts"
    },
    "./components/tabs/tabs.css": "./dist/components/tabs/tabs.css",
    "./components/tooltip": {
      "import": "./dist/components/tooltip/index.js",
      "types": "./dist/components/tooltip/index.d.ts"
    },
    "./components/tooltip/tooltip.css": "./dist/components/tooltip/tooltip.css",
    "./tokens/color.css": "./dist/tokens/color.css",
    "./tokens/typography.css": "./dist/tokens/typography.css",
    "./tokens/spacing.css": "./dist/tokens/spacing.css",
    "./tokens/radius.css": "./dist/tokens/radius.css",
    "./tokens/shadow.css": "./dist/tokens/shadow.css",
    "./tokens/motion.css": "./dist/tokens/motion.css",
    "./tokens/z-index.css": "./dist/tokens/z-index.css"
  },
  "devDependencies": {
    "postcss": "^8.5.16",
    "stylelint": "^17.14.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
