---
// Terrain de jeu visuel : rend chaque variante/taille/état de chaque composant
// avec le CSS réellement buildé de @tds-tchad/core (copié dans public/tds/ par
// scripts/copy-core-assets.mjs). Sert de QA visuelle rapide — remplace le
// placeholder apps/storybook, qui n'apportait rien pour une bibliothèque
// 100% CSS sans état/props JS à piloter.
const buttonVariants = ['primary', 'secondary', 'tertiary', 'danger', 'success'];
const buttonSizes = ['sm', 'md', 'lg'];
const inputVariants = ['default', 'error', 'success'];
const badgeVariants = ['default', 'info', 'success', 'warning', 'danger'];
const alertVariants = ['info', 'success', 'warning', 'danger'];
const cardVariants = ['flat', 'elevated', 'outlined'];
const linkVariants = ['default', 'muted', 'danger', 'external', 'nav', 'standalone'];
const breadcrumbTrail = [
  { label: 'Accueil', href: '#' },
  { label: 'Démarches', href: '#' },
  { label: 'Renouvellement de carte' },
];
const paginationPages = [1, 2, 3, 4, 5];
---
<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <title>TDS — Terrain de jeu des composants</title>
  <link rel="stylesheet" href="/tds/base.css" />
  <link rel="stylesheet" href="/tds/tokens/color.css" />
  <link rel="stylesheet" href="/tds/tokens/typography.css" />
  <link rel="stylesheet" href="/tds/tokens/spacing.css" />
  <link rel="stylesheet" href="/tds/tokens/radius.css" />
  <link rel="stylesheet" href="/tds/tokens/shadow.css" />
  <link rel="stylesheet" href="/tds/tokens/motion.css" />
  <link rel="stylesheet" href="/tds/tokens/z-index.css" />
  <link rel="stylesheet" href="/tds/components/button/button.css" />
  <link rel="stylesheet" href="/tds/components/input/input.css" />
  <link rel="stylesheet" href="/tds/components/alert/alert.css" />
  <link rel="stylesheet" href="/tds/components/badge/badge.css" />
  <link rel="stylesheet" href="/tds/components/card/card.css" />
  <link rel="stylesheet" href="/tds/components/link/link.css" />
  <link rel="stylesheet" href="/tds/components/table/table.css" />
  <link rel="stylesheet" href="/tds/components/header/header.css" />
  <link rel="stylesheet" href="/tds/components/nav/nav.css" />
  <link rel="stylesheet" href="/tds/components/breadcrumb/breadcrumb.css" />
  <link rel="stylesheet" href="/tds/components/pagination/pagination.css" />
  <link rel="stylesheet" href="/tds/components/modal/modal.css" />
  <style>
    body { max-width: 72rem; margin: 0 auto; padding: var(--tds-spacing-8); font-family: var(--tds-font-family-primary); }
    section { margin-bottom: var(--tds-spacing-16); }
    h2 { border-bottom: 1px solid var(--tds-neutral-200); padding-bottom: var(--tds-spacing-2); }
    .row { display: flex; flex-wrap: wrap; align-items: center; gap: var(--tds-spacing-4); margin-bottom: var(--tds-spacing-4); }
    .row-label { width: 8rem; font-size: var(--tds-font-size-sm); color: var(--tds-neutral-600); }
  </style>
</head>
<body>
<main>
  <h1>TDS — Terrain de jeu des composants</h1>
  <p>Rend chaque variante × taille × état à partir du CSS réellement buildé (<code>packages/core/dist</code>). Page de QA visuelle, non indexée, non liée depuis la navigation Starlight.</p>

  <section id="button" data-pagefind-ignore>
    <h2>Button</h2>
    {buttonSizes.map((size) => (
      <div class="row">
        <span class="row-label">{size}</span>
        {buttonVariants.map((variant) => (
          <button type="button" class={`tds-button tds-button--${variant} tds-button--${size}`}>
            {variant}
          </button>
        ))}
      </div>
    ))}
    <div class="row">
      <span class="row-label">disabled</span>
      <button type="button" class="tds-button tds-button--primary tds-button--md" disabled>primary</button>
      <button type="button" class="tds-button tds-button--secondary tds-button--md" aria-disabled="true">secondary</button>
    </div>
    <div class="row">
      <span class="row-label">loading</span>
      <button type="button" class="tds-button tds-button--primary tds-button--md" data-loading="true">Envoi…</button>
    </div>
  </section>

  <section id="input" data-pagefind-ignore>
    <h2>Input</h2>
    {['sm', 'md', 'lg'].map((size) => (
      <div class="row">
        <span class="row-label">{size}</span>
        {inputVariants.map((variant) => (
          <div class="tds-field">
            <label class="tds-field__label" for={`input-${size}-${variant}`}>{variant}</label>
            <input id={`input-${size}-${variant}`} type="text" class={`tds-input tds-input--${size} ${variant !== 'default' ? `tds-input--${variant}` : ''}`} placeholder="Texte…" />
          </div>
        ))}
      </div>
    ))}
    <div class="row">
      <span class="row-label">disabled</span>
      <div class="tds-field">
        <label class="tds-field__label" for="input-disabled">Champ désactivé</label>
        <input id="input-disabled" type="text" class="tds-input tds-input--md tds-input--disabled" value="Champ désactivé" disabled />
      </div>
      <div class="tds-field">
        <label class="tds-field__label" for="input-readonly">Lecture seule</label>
        <input id="input-readonly" type="text" class="tds-input tds-input--md tds-input--readonly" value="Lecture seule" readonly />
      </div>
    </div>
  </section>

  <section id="alert" data-pagefind-ignore>
    <h2>Alert</h2>
    {alertVariants.map((variant) => (
      <div class={`tds-alert tds-alert--${variant}`} role="status" style="margin-bottom: var(--tds-spacing-3);">
        <div class="tds-alert__content">
          <p class="tds-alert__title">Titre {variant}</p>
          <div class="tds-alert__body">Message d'exemple pour la variante {variant}.</div>
        </div>
      </div>
    ))}
  </section>

  <section id="badge" data-pagefind-ignore>
    <h2>Badge</h2>
    {['sm', 'md'].map((size) => (
      <div class="row">
        <span class="row-label">{size}</span>
        {badgeVariants.map((variant) => (
          <span class={`tds-badge tds-badge--${variant} tds-badge--${size}`}>{variant}</span>
        ))}
      </div>
    ))}
  </section>

  <section id="card" data-pagefind-ignore>
    <h2>Card</h2>
    <div class="row">
      {cardVariants.map((variant) => (
        <div class={`tds-card tds-card--${variant}`} style="width: 16rem;">
          <div class="tds-card__body">
            <p class="tds-card__title">Carte {variant}</p>
            <p class="tds-card__description">Contenu d'exemple pour la variante {variant}.</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section id="link" data-pagefind-ignore>
    <h2>Link</h2>
    <div class="row">
      {linkVariants.map((variant) => (
        <a href="#" class={`tds-link ${variant !== 'default' ? `tds-link--${variant}` : ''}`}>Lien {variant}</a>
      ))}
    </div>
  </section>

  <section id="table" data-pagefind-ignore>
    <h2>Table</h2>
    <div class="tds-table-wrapper">
      <table class="tds-table tds-table--striped tds-table--bordered">
        <caption>Exemple de tableau strié et bordé</caption>
        <thead>
          <tr><th scope="col">Référence</th><th scope="col">Statut</th><th scope="col">Montant</th></tr>
        </thead>
        <tbody>
          <tr><td>REF-001</td><td data-status="success">Validé</td><td>12 400 FCFA</td></tr>
          <tr><td>REF-002</td><td data-status="warning">En attente</td><td>8 000 FCFA</td></tr>
          <tr><td>REF-003</td><td data-status="danger">Rejeté</td><td>3 200 FCFA</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section id="header" data-pagefind-ignore>
    <h2>Header</h2>
    <div class="tds-header" style="border: 1px solid var(--tds-neutral-200); margin-bottom: var(--tds-spacing-3);">
      <a href="#" class="tds-header__brand">
        <div class="tds-header__titles">
          <span class="tds-header__title">République du Tchad</span>
          <span class="tds-header__tagline">Ministère du Numérique</span>
        </div>
      </a>
      <div class="tds-header__actions">
        <a href="#" class="tds-link">Se connecter</a>
      </div>
    </div>
    <div class="tds-header tds-header--compact" style="border: 1px solid var(--tds-neutral-200);">
      <a href="#" class="tds-header__brand">
        <span class="tds-header__title">Variante compacte</span>
      </a>
    </div>
  </section>

  <section id="nav" data-pagefind-ignore>
    <h2>Navigation</h2>
    <nav class="tds-nav" aria-label="Navigation principale" style="margin-bottom: var(--tds-spacing-3);">
      <ul class="tds-nav__list">
        <li><a href="#" class="tds-nav__link" aria-current="page">Accueil</a></li>
        <li><a href="#" class="tds-nav__link">Démarches</a></li>
        <li><a href="#" class="tds-nav__link">Services</a></li>
        <li><a href="#" class="tds-nav__link">Contact</a></li>
      </ul>
    </nav>
    <nav class="tds-nav tds-nav--muted" aria-label="Navigation secondaire">
      <ul class="tds-nav__list">
        <li><a href="#" class="tds-nav__link">Sous-section A</a></li>
        <li><a href="#" class="tds-nav__link" aria-current="page">Sous-section B</a></li>
      </ul>
    </nav>
  </section>

  <section id="breadcrumb" data-pagefind-ignore>
    <h2>Breadcrumb</h2>
    <nav class="tds-breadcrumb" aria-label="Fil d'Ariane">
      <ol class="tds-breadcrumb__list">
        {breadcrumbTrail.map((item, i) => (
          <li class="tds-breadcrumb__item">
            {item.href
              ? <a href={item.href} class="tds-breadcrumb__link">{item.label}</a>
              : <span class="tds-breadcrumb__current" aria-current="page">{item.label}</span>}
          </li>
        ))}
      </ol>
    </nav>
  </section>

  <section id="pagination" data-pagefind-ignore>
    <h2>Pagination</h2>
    <nav aria-label="Pagination">
      <ul class="tds-pagination__list">
        <li><a href="#" class="tds-pagination__link" aria-disabled="true" aria-label="Page précédente">‹</a></li>
        {paginationPages.map((page) => (
          <li><a href="#" class="tds-pagination__link" aria-current={page === 1 ? 'page' : undefined} aria-label={`Page ${page}`}>{page}</a></li>
        ))}
        <li><span class="tds-pagination__ellipsis">…</span></li>
        <li><a href="#" class="tds-pagination__link" aria-label="Page 12">12</a></li>
        <li><a href="#" class="tds-pagination__link" aria-label="Page suivante">›</a></li>
      </ul>
    </nav>
  </section>

  <section id="modal" data-pagefind-ignore>
    <h2>Modal</h2>
    <p>Rendu statique (attribut <code>open</code>) pour la QA visuelle — l'ouverture réelle passe par <code>dialog.showModal()</code> côté consommateur.</p>
    <dialog class="tds-modal" open style="position: static; margin: 0;">
      <div class="tds-modal__header">
        <h3 class="tds-modal__title">Confirmer la soumission</h3>
        <button type="button" class="tds-modal__close" aria-label="Fermer">✕</button>
      </div>
      <div class="tds-modal__body">
        <p>Votre demande sera transmise au service concerné. Cette action est définitive.</p>
      </div>
      <div class="tds-modal__footer">
        <button type="button" class="tds-button tds-button--tertiary tds-button--md">Annuler</button>
        <button type="button" class="tds-button tds-button--primary tds-button--md">Confirmer</button>
      </div>
    </dialog>
  </section>
</main>
</body>
</html>
